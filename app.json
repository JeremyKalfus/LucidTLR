{
  "expo": {
    "name": "LucidCue",
    "slug": "lucidcue",
    "scheme": "lucidcue",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jeremykalfus.lucidcue",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "LucidCue uses microphone access only for local debug feasibility audio analysis when explicitly enabled on the hidden development screen.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0C0C0C"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1927a3da-a23c-4160-b86e-a312d9326558"
      }
    }
  }
}
